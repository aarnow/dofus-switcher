{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main", "overlay"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "core:window:allow-start-dragging"
  ]
}
